          {
            "id": "mqvolicxspab00",
            "label": "西昌学院",
            "expanded": true,
            "attachments": [
              {
                "id": "mqvy0iwe73ksee",
                "type": "note",
                "name": "笔记_2026-06-27",
                "data": "<div class=\"detail\" style=\"margin: auto; box-sizing: content-box; position: relative; text-align: justify; font-size: 16px; color: rgb(51, 51, 51); line-height: 28px; font-family: &quot;Microsoft YaHei&quot;, &quot;WenQuanYi Micro Hei&quot;, &quot;Helvetica Neue&quot;, Verdana, Arial, Helvetica, SimHei, sans-serif; white-space: normal;\"><p align=\"center\" style=\"margin: 0pt 0pt 0.0001pt; box-sizing: content-box; text-align: center;\"><span style=\"box-sizing: content-box; font-size: 10.5pt;\"><span style=\"box-sizing: content-box; font-family: Calibri;\"><span style=\"box-sizing: content-box; font-weight: 700;\"><span style=\"box-sizing: content-box; font-size: 22pt;\"><span style=\"box-sizing: content-box; font-family: &quot;Times New Roman&quot;;\"><span style=\"box-sizing: content-box;\"><font face=\"黑体\" style=\"box-sizing: content-box;\">西昌学院</font></span></span></span></span><span style=\"box-sizing: content-box; font-weight: 700;\"><span style=\"box-sizing: content-box; font-size: 22pt;\"><span style=\"box-sizing: content-box; font-family: 黑体;\"><span style=\"box-sizing: content-box;\"><font face=\"Times New Roman\" style=\"box-sizing: content-box;\">2026</font><font face=\"黑体\" style=\"box-sizing: content-box;\">年</font></span></span></span></span><span style=\"box-sizing: content-box; font-weight: 700;\"><span style=\"box-sizing: content-box; font-size: 22pt;\"><span style=\"box-sizing: content-box; font-family: &quot;Times New Roman&quot;;\"><span style=\"box-sizing: content-box;\"><font face=\"黑体\" style=\"box-sizing: content-box;\">普通高等教育本科</font></span></span></span></span></span></span></p><p align=\"center\" style=\"margin: 0pt 0pt 0.0001pt; box-sizing: content-box; text-align: center;\"><span style=\"box-sizing: content-box; font-size: 10.5pt;\"><span style=\"box-sizing: content-box; font-family: Calibri;\"><span style=\"box-sizing: content-box; font-weight: 700;\"><span style=\"box-sizing: content-box; font-size: 22pt;\"><span style=\"box-sizing: content-box; font-family: &quot;Times New Roman&quot;;\"><span style=\"box-sizing: content-box;\"><font face=\"黑体\" style=\"box-sizing: content-box;\">招生章程</font></span></span></span></span></span></span></p><p align=\"center\" style=\"margin: 0pt 0pt 0.0001pt; box-sizing: content-box; text-align: center;\"><span style=\"box-sizing: content-box; font-size: 10.5pt;\"><span style=\"box-sizing: content-box; font-family: Calibri;\"><span style=\"box-sizing: content-box; font-size: 16pt;\"><span style=\"box-sizing: content-box; font-family: 黑体;\"><font face=\"黑体\" style=\"box-sizing: content-box;\">第一章</font>&nbsp;&nbsp;<font face=\"黑体\" style=\"box-sizing: content-box;\">总则</font></span></span></span></span></p><p style=\"margin: 0pt 0pt 0.0001pt; box-sizing: content-box;\"><span style=\"box-sizing: content-box; font-size: 10.5pt;\"><span style=\"box-sizing: content-box; font-family: Calibri;\"><span style=\"box-sizing: content-box; font-size: 16pt;\"><span style=\"box-sizing: content-box; font-family: 黑体;\"><font face=\"黑体\" style=\"box-sizing: content-box;\">第一条</font>&nbsp;&nbsp;</span></span><span style=\"box-sizing: content-box; font-size: 16pt;\"><span style=\"box-sizing: content-box; font-family: &quot;Times New Roman&quot;;\"><font face=\"仿宋\" style=\"box-sizing: content-box;\">根据《中华人民共和国教育法》《中华人民共和国高等教育法》等法律和教育部有关规定，为维护广大考生和学校的合法权益，并结合我校招生录取工作的实际情况，特制定本章程。</font></span></span></span></span></p><p style=\"margin: 0pt 0pt 0.0001pt; box-sizing: content-box;\"><span style=\"box-sizing: content-box; font-size: 10.5pt;\"><span style=\"box-sizing: content-box; font-family: Calibri;\"><span style=\"box-sizing: content-box; font-size: 16pt;\"><span style=\"box-sizing: content-box; font-family: 黑体;\"><font face=\"黑体\" style=\"box-sizing: content-box;\">第二条</font>&nbsp;&nbsp;</span></span><span style=\"box-sizing: content-box; font-size: 16pt;\"><span style=\"box-sizing: content-box; font-family: &quot;Times New Roman&quot;;\"><font face=\"仿宋\" style=\"box-sizing: content-box;\">西昌学院招生录取工作执行教育部规定的</font></span></span><span style=\"box-sizing: content-box; font-size: 16pt;\"><span style=\"box-sizing: content-box; font-family: 仿宋;\"><font face=\"仿宋\" style=\"box-sizing: content-box;\">“</font></span></span><span style=\"box-sizing: content-box; font-size: 16pt;\"><span style=\"box-sizing: content-box; font-family: &quot;Times New Roman&quot;;\"><font face=\"仿宋\" style=\"box-sizing: content-box;\">学校负责、考试院监督</font></span></span><span style=\"box-sizing: content-box; font-size: 16pt;\"><span style=\"box-sizing: content-box; font-family: 仿宋;\"><font face=\"仿宋\" style=\"box-sizing: content-box;\">”</font></span></span><span style=\"box-sizing: content-box; font-size: 16pt;\"><span style=\"box-sizing: content-box; font-family: &quot;Times New Roman&quot;;\"><font face=\"仿宋\" style=\"box-sizing: content-box;\">的录取体制，在各省（自治区、直辖市）招生委员会统一组织下进行。贯彻公平竞争、公正选拔，德智体全面考核，择优录取的原则，</font></span></span><span style=\"box-sizing: content-box; font-size: 16pt;\"><span style=\"box-sizing: content-box; font-family: 仿宋;\"><font face=\"仿宋\" style=\"box-sizing: content-box;\">落实</font></span></span><span style=\"box-sizing: content-box; font-size: 16pt;\"><span style=\"box-sizing: content-box; font-family: &quot;Times New Roman&quot;;\"><font face=\"仿宋\" style=\"box-sizing: content-box;\">招生</font></span></span><span style=\"box-sizing: content-box; font-size: 16pt;\"><span style=\"box-sizing: content-box; font-family: 仿宋;\"><font face=\"仿宋\" style=\"box-sizing: content-box;\">“</font></span></span><span style=\"box-sizing: content-box; font-size: 16pt;\"><span style=\"box-sizing: content-box; font-family: &quot;Times New Roman&quot;;\"><font face=\"仿宋\" style=\"box-sizing: content-box;\">阳光工程</font></span></span><span style=\"box-sizing: content-box; font-size: 16pt;\"><span style=\"box-sizing: content-box; font-family: 仿宋;\"><font face=\"仿宋\" style=\"box-sizing: content-box;\">”</font></span></span><span style=\"box-sizing: content